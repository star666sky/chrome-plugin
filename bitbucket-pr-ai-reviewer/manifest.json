{
  "manifest_version": 3,
  "name": "Bitbucket PR AI Reviewer",
  "version": "0.1.0",
  "description": "Reviews Bitbucket pull request diffs on code.fineres.com with DeepSeek.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://code.fineres.com/*", "https://api.deepseek.com/*"],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://code.fineres.com/*"],
      "js": ["src/pr-url-match.js", "src/panel-position.js", "src/content.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Bitbucket AI Review"
  }
}
